{
  "name": "elementra",
  "private": true,
  "version": "0.1.0",
  "description": "An interactive, accessible periodic table and chemistry reference dashboard.",
  "license": "MIT",
  "homepage": "https://subir31.github.io/elementra/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Subir31/elementra.git"
  },
  "bugs": {
    "url": "https://github.com/Subir31/elementra/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
